# ============================================================
# VeriQuery .gitignore
# ============================================================

# ==================== Python ====================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ==================== IDEs ====================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==================== Operating System ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ==================== Application Specific ====================
# Data directories (all runtime data, regenerated on each run)
data/uploads/*
!data/uploads/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/cache/*
!data/cache/.gitkeep
data/images/*
!data/images/.gitkeep
data/chroma/*
!data/chroma/.gitkeep
data/vector_db/*
!data/vector_db/.gitkeep
data/vectors/*
!data/vectors/.gitkeep
data/circuit_images/*
!data/circuit_images/.gitkeep
data/visual_index/*
!data/visual_index/.gitkeep
data/db_backups/*
!data/db_backups/.gitkeep

# Runtime database files (regenerated on each run)
data/bm25_index.pkl
data/documents.db
data/documents_db.json
data/knowledge_graph.db
data/tables.db

# Experiment backup (moved out of project)
experiment_backup/

# Logs
logs/*
!logs/.gitkeep
*.log

# Models (如果本地下载)
models/
*.bin
*.safetensors
*.gguf

# ==================== Docker ====================
# Docker volumes
docker-volumes/

# ==================== Temporary Files ====================
*.tmp
*.temp
*.swp
*.swo
*~

# ==================== Security ====================
# 敏感配置文件
.env
.env.local
.env.*.local
*.key
*.pem
*.cert
secrets/

# ==================== Package Managers ====================
# npm
node_modules/
package-lock.json

# Yarn
yarn.lock
.yarn/

# ==================== Build Artifacts ====================
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ==================== Streamlit ====================
.streamlit/secrets.toml

# ==================== Miscellaneous ====================
# Backup files
*.bak
*.backup
*~

# Large files (use Git LFS for these if needed)
*.h5
*.pkl
*.joblib
*.model
