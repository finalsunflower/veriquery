# ============================================================
# VeriQuery Environment Configuration
# ============================================================
# Copy this file to .env and modify as needed.
# Models are automatically downloaded from HuggingFace on first run.

# ==================== Application ====================
DEBUG=false
APP_NAME=VeriQuery

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# ==================== LLM Configuration ====================
# HuggingFace model ID or local path. Auto-downloaded on first run.
# Recommended models (choose one based on your GPU VRAM):
#   - Qwen/Qwen2.5-0.5B      (1GB VRAM, fastest)
#   - Qwen/Qwen2.5-1.5B      (2GB VRAM)
#   - Qwen/Qwen2.5-3B        (4GB VRAM)
#   - Qwen/Qwen2.5-7B        (8GB VRAM, best quality)
#   - Qwen/Qwen3-0.6B        (1GB VRAM, newest)
#   - Qwen/Qwen3-1.7B        (2GB VRAM, newest)
#   - Qwen/Qwen3-4B          (4GB VRAM, newest)
LLM_MODEL=Qwen/Qwen2.5-1.5B
LLM_DEVICE=cuda
LLM_QUANTIZE=true
LLM_QUANTIZATION_BITS=4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=256

# ==================== VLM Configuration ====================
# Vision-Language Model for diagram understanding and CLIP-based image filtering.
# Auto-downloaded from HuggingFace on first run.
#   - Qwen/Qwen2-VL-2B-Instruct     (4GB VRAM)
#   - Qwen/Qwen2-VL-7B-Instruct     (8GB VRAM, recommended)
VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
VLM_QUANTIZE=true
VLM_QUANTIZATION_BITS=4

# ==================== CLIP Configuration ====================
# CLIP model for image classification and filtering.
# Auto-downloaded from HuggingFace on first run.
CLIP_MODEL=openai/clip-vit-base-patch32
CLIP_THRESHOLD=0.25

# ==================== Embedding Configuration ====================
# Text embedding model for vector retrieval.
# Auto-downloaded from HuggingFace on first run.
#   - BAAI/bge-large-zh-v1.5         (1024-dim, Chinese+English)
#   - BAAI/bge-m3                     (1024-dim, multilingual)
#   - Qwen/Qwen3-Embedding-0.6B      (1024-dim, newest)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cuda
EMBEDDING_DIMENSION=1024

# ==================== Vector Database ====================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=veriquery_text

# ==================== Storage Paths ====================
DATA_DIR=./data

# ==================== Hybrid Retrieval ====================
VECTOR_WEIGHT=0.50
BM25_WEIGHT=0.35
STRUCTURED_WEIGHT=0.15

# ==================== Text Chunking ====================
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# ==================== GPU Memory ====================
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512,expandable_segments:True,garbage_collection_threshold:0.8

# ==================== SVG Rendering ====================
SVG_DEFAULT_PACKAGE=DIP-8
SVG_SHOW_LEGEND=true
